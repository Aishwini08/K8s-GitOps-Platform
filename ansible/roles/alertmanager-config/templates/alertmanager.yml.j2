global:
  resolve_timeout: 5m
  slack_api_url: "{{ slack_webhook_url }}"

route:
  group_by: ["alertname", "namespace"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 12h
  receiver: "slack-notifications"
  routes:
    - receiver: "null"
      matchers:
        - alertname = "Watchdog"

receivers:
  - name: "null"
  - name: "slack-notifications"
    slack_configs:
      - channel: "{{ slack_channel }}"
        send_resolved: true
        title: "{{ '{{' }} .GroupLabels.alertname {{ '}}' }}"
        text: >-
          {{ '{{' }} range .Alerts {{ '}}' }}
            *Alert:* {{ '{{' }} .Annotations.summary {{ '}}' }}
            *Severity:* {{ '{{' }} .Labels.severity {{ '}}' }}
          {{ '{{' }} end {{ '}}' }}

inhibit_rules:
  - source_matchers:
      - severity = critical
    target_matchers:
      - severity =~ warning|info
    equal:
      - namespace
      - alertname
